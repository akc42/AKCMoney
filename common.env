DEBUG_CACHE_SIZE=50
SQLITE_DB_DIR=/db
SQLITE_DB_NAME=money
SQLITE_DB_POOL_MIN_DB=2
SQLITE_DB_POOL_MAX_DB=100
SQLITE_DB_BACKUP_DIR=/db-backup
MONEY_DB_VERSION=2
MONEY_DB_INIT_DIR=/app/server/db-init
MONEY_TRACKING=no
MONEY_VERSION_FILE=../appinfo/version